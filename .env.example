# Environment Variables Template
# Copy this to .env.local (for local dev) or .env.prod (for production)
# Never commit .env files with real values

# ============================================
# Database (required)
# ============================================
# PostgreSQL connection string
# Local: postgresql://rateanything:password@localhost:5432/rateanything
# Supabase: postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres
DATABASE_URL=

# ============================================
# Clerk Authentication (required)
# ============================================
# Get from https://dashboard.clerk.com
# Test keys: pk_test_..., sk_test_... (for localhost)
# Live keys: pk_live_..., sk_live_... (for production domain)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ============================================
# App URL (optional)
# ============================================
# Used for share cards, redirects, etc.
# Local: http://localhost:3000
# Production: https://rating.fyi
NEXT_PUBLIC_APP_URL=

# ============================================
# Redis (optional — for workers)
# ============================================
# Local: redis://localhost:6379
# Upstash: rediss://default:password@host.upstash.io:6379
REDIS_URL=

# ============================================
# Supabase Client SDK (optional)
# ============================================
# Only needed if using @supabase/supabase-js directly
# Get from https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ============================================
# Vercel (auto-injected — don't set manually)
# ============================================
VERCEL_OIDC_TOKEN=
